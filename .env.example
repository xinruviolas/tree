# Google OAuth — https://docs.expo.dev/guides/google-authentication/
#
# Web (browser, including iPhone Safari): Web client ID. Add Authorized redirect URIs that match
# your dev URL, e.g. http://192.168.1.x:8081 or http://localhost:8081 (same origin as the app).
#
# Expo Go on a phone: use Web client ID with Expo proxy. In Google Cloud, add Authorized redirect URI
#   https://auth.expo.io/@YOUR_EXPO_USERNAME/tree
# Google requires the Web client's Client secret to exchange the auth code — set it below for
# local dev only (do not ship a public app with this; use a dev build + iOS OAuth client for prod).
# If @user/slug is not inferred, set EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME.
EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_SECRET=

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Standalone / dev build / TestFlight (not Expo Go): iOS OAuth client ID (bundle com.xinruli.tree).
# Optional until Android is in scope:
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
